{
  "name": "@manus/ms-graph-mcp",
  "version": "0.1.0",
  "description": "A JSR-based TypeScript MCP package for personal Microsoft Graph access via CLI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ms-graph-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --format esm",
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.0",
    "msal-node": ">=4.0.0 <6.0.0",
    "commander": "^12.0.0",
    "zod": "^3.22.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}
